# Copy this file to .env (for local dev) and fill in the values from your
# Supabase project: Settings -> API.
#
# Both variables are safe to expose to the browser — the anon key only ever
# grants the permissions you define with Row Level Security policies
# (see supabase/schema.sql).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
